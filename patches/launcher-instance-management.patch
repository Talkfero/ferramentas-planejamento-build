+    def close_instances(self, executable: str, timeout: float = 5.0) -> List[RunningProcess]:
+        """Fecha processos que estejam usando o executável informado."""
+        target = _normalize_path(executable)
+        if not target:
+            return []
+
+        closed_tracked: set[int] = set()
+        failed: List[RunningProcess] = []
+        for proc in list(self._procs):
+            if proc.poll() is not None:
+                self.forget(proc)
+                continue
+            if not _same_executable(_proc_args_path(proc), target):
+                continue
+            if _close_popen(proc, timeout=timeout):
+                closed_tracked.add(proc.pid)
+                self.forget(proc)
+            else:
+                failed.append(RunningProcess(proc.pid, target))
+
+        for proc in self.find_instances(executable):
+            if proc.pid in closed_tracked or any(p.pid == proc.pid for p in failed):
+                continue
+            if not _close_pid(proc.pid, timeout=timeout):
+                failed.append(proc)
+        self._procs = [p for p in self._procs if p.poll() is None]
+        return failed
