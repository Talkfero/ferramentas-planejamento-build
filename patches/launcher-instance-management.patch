+def _proc_args_path(proc: subprocess.Popen) -> Optional[str]:
+    args = proc.args
+    if isinstance(args, (list, tuple)) and args:
+        first = args[0]
+        return first if isinstance(first, str) else None
+    return args if isinstance(args, str) else None
+
+
+def _normalize_path(path: Optional[str]) -> Optional[str]:
+    if not path:
+        return None
+    try:
+        return os.path.normcase(os.path.abspath(path))
+    except (OSError, ValueError):
+        return None
+
+
+def _same_executable(left: Optional[str], right: Optional[str]) -> bool:
+    return bool(left and right and _normalize_path(left) == _normalize_path(right))
+
+
+def _iter_processes_by_executable(executable: str) -> Iterable[RunningProcess]:
+    if sys.platform.startswith("win"):
+        yield from _iter_windows_processes_by_executable(executable)
+    else:
+        yield from _iter_procfs_processes_by_executable(executable)
+
+
+def _iter_procfs_processes_by_executable(executable: str) -> Iterable[RunningProcess]:
+    proc_root = "/proc"
+    if not os.path.isdir(proc_root):
+        return
+    for name in os.listdir(proc_root):
+        if not name.isdigit():
+            continue
+        pid = int(name)
+        exe_link = os.path.join(proc_root, name, "exe")
+        try:
+            proc_exe = os.readlink(exe_link)
+        except OSError:
+            continue
+        if _same_executable(proc_exe, executable):
+            yield RunningProcess(pid, proc_exe)
+
+
+def _iter_windows_processes_by_executable(executable: str) -> Iterable[RunningProcess]:
+    kernel32 = ctypes.WinDLL("kernel32", use_last_error=True)
+    psapi = ctypes.WinDLL("psapi", use_last_error=True)
+
+    enum_processes = psapi.EnumProcesses
+    enum_processes.argtypes = [
+        ctypes.POINTER(wintypes.DWORD),
+        wintypes.DWORD,
+        ctypes.POINTER(wintypes.DWORD),
+    ]
+    enum_processes.restype = wintypes.BOOL
+
+    open_process = kernel32.OpenProcess
+    open_process.argtypes = [wintypes.DWORD, wintypes.BOOL, wintypes.DWORD]
+    open_process.restype = wintypes.HANDLE
+
+    close_handle = kernel32.CloseHandle
+    close_handle.argtypes = [wintypes.HANDLE]
+
+    query_image = kernel32.QueryFullProcessImageNameW
+    query_image.argtypes = [
+        wintypes.HANDLE,
+        wintypes.DWORD,
+        wintypes.LPWSTR,
+        ctypes.POINTER(wintypes.DWORD),
+    ]
+    query_image.restype = wintypes.BOOL
+
+    process_query_limited_information = 0x1000
+    process_count = 4096
+    while True:
+        arr = (wintypes.DWORD * process_count)()
+        needed = wintypes.DWORD()
+        if not enum_processes(arr, ctypes.sizeof(arr), ctypes.byref(needed)):
+            return
+        count = needed.value // ctypes.sizeof(wintypes.DWORD)
+        if count < process_count:
+            break
+        process_count *= 2
+
+    for pid in arr[:count]:
+        if not pid or pid == os.getpid():
+            continue
+        handle = open_process(process_query_limited_information, False, pid)
+        if not handle:
+            continue
+        try:
+            size = wintypes.DWORD(32768)
+            buf = ctypes.create_unicode_buffer(size.value)
+            if not query_image(handle, 0, buf, ctypes.byref(size)):
+                continue
+            proc_exe = buf.value
+        finally:
+            close_handle(handle)
+        if _same_executable(proc_exe, executable):
+            yield RunningProcess(int(pid), proc_exe)
+
+
+def _close_pid(pid: int, timeout: float) -> bool:
+    if pid == os.getpid():
+        return False
+    if sys.platform.startswith("win"):
+        return _close_windows_pid(pid, timeout)
+    return _close_posix_pid(pid, timeout)
+
+
+def _close_popen(proc: subprocess.Popen, timeout: float) -> bool:
+    try:
+        proc.terminate()
+        try:
+            proc.wait(timeout=timeout)
+            return True
+        except subprocess.TimeoutExpired:
+            proc.kill()
+            proc.wait(timeout=timeout)
+            return True
+    except (OSError, subprocess.TimeoutExpired) as exc:
+        logger.warning("Falha ao encerrar processo rastreado %s: %s", proc.pid, exc)
+        return False
+
+
+def _close_windows_pid(pid: int, timeout: float) -> bool:
+    try:
+        subprocess.run(
+            ["taskkill", "/PID", str(pid), "/T"],
+            check=False,
+            stdout=subprocess.DEVNULL,
+            stderr=subprocess.DEVNULL,
+            creationflags=_subprocess_creationflags(),
+        )
+        if _wait_pid_exit(pid, timeout):
+            return True
+        subprocess.run(
+            ["taskkill", "/PID", str(pid), "/T", "/F"],
+            check=False,
+            stdout=subprocess.DEVNULL,
+            stderr=subprocess.DEVNULL,
+            creationflags=_subprocess_creationflags(),
+        )
+        return _wait_pid_exit(pid, timeout)
+    except OSError as exc:
+        logger.warning("Falha ao encerrar PID %s: %s", pid, exc)
+        return False
+
+
+def _close_posix_pid(pid: int, timeout: float) -> bool:
+    try:
+        os.kill(pid, 15)
+        if _wait_pid_exit(pid, timeout):
+            return True
+        os.kill(pid, 9)
+        return _wait_pid_exit(pid, timeout)
+    except OSError as exc:
+        logger.warning("Falha ao encerrar PID %s: %s", pid, exc)
+        return False
+
+
+def _wait_pid_exit(pid: int, timeout: float) -> bool:
+    deadline = time.monotonic() + timeout
+    while time.monotonic() < deadline:
+        if not _pid_exists(pid):
+            return True
+        time.sleep(0.1)
+    return not _pid_exists(pid)
+
+
+def _pid_exists(pid: int) -> bool:
+    if pid <= 0:
+        return False
+    try:
+        os.kill(pid, 0)
+    except ProcessLookupError:
+        return False
+    except PermissionError:
+        return True
+    except OSError:
+        return False
+    return True
+
