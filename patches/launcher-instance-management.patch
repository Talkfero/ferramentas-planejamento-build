+    def find_instances(self, executable: str) -> List[RunningProcess]:
+        """Retorna processos em execução que usam exatamente este executável."""
+        target = _normalize_path(executable)
+        if not target:
+            return []
+
+        tracked = [
+            RunningProcess(proc.pid, target)
+            for proc in self._procs
+            if proc.poll() is None and _same_executable(_proc_args_path(proc), target)
