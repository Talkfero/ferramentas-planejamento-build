@@ -0,0 +1,41 @@
+# -*- coding: utf-8 -*-
+"""Testes do gerenciamento de instâncias externas."""
+import subprocess
+import sys
+
+from app.process import ProcessManager, RunningProcess
+
+
+def test_find_instances_deduplicates_tracked_and_discovered(monkeypatch, tmp_path):
+    exe = tmp_path / "App.exe"
+    exe.write_bytes(b"MZ")
+
+    manager = ProcessManager()
+    tracked = subprocess.Popen([sys.executable, "-c", "pass"])
+    manager._procs.append(tracked)
+
+    monkeypatch.setattr("app.process._proc_args_path", lambda _proc: str(exe))
+    monkeypatch.setattr(
+        "app.process._iter_processes_by_executable",
+        lambda _target: [RunningProcess(tracked.pid, str(exe))],
+    )
+
+    try:
+        found = manager.find_instances(str(exe))
+    finally:
+        tracked.wait(timeout=5)
+
+    assert found == [RunningProcess(tracked.pid, str(exe))]
+
+
+def test_close_instances_reports_failures(monkeypatch, tmp_path):
+    exe = tmp_path / "App.exe"
+    exe.write_bytes(b"MZ")
+    manager = ProcessManager()
+
+    monkeypatch.setattr(
+        manager,
+        "find_instances",
+        lambda _target: [RunningProcess(12345, str(exe)), RunningProcess(67890, str(exe))],
+    )
+    monkeypatch.setattr("app.process._close_pid", lambda pid, timeout: pid == 12345)
+
+    failed = manager.close_instances(str(exe))
+
+    assert failed == [RunningProcess(67890, str(exe))]
